# ============================================================
# PLAINER — Variables d'entorn
# Copia aquest fitxer com .env.local i omple els valors
# ============================================================

# --- Base de dades (Supabase) --------------------------------
# Supabase Dashboard → Settings → Database → Connection string
# Usa el mode "Transaction" o "Session" (pooler), NO la connexió directa
# Format: postgresql://postgres.[project-ref]:[password]@aws-X-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=""

# --- NextAuth ------------------------------------------------
# URL de l'app (canvia-la en producció a la URL real)
NEXTAUTH_URL="http://localhost:3000"
# Genera un secret aleatori: openssl rand -base64 32
NEXTAUTH_SECRET=""

# --- Google OAuth -------------------------------------------
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Resend (emails de reset de contrasenya) ----------------
# Crea un compte a resend.com i genera una API key
RESEND_API_KEY=""
# Domeni verificat a Resend (o usa el domini de prova onboarding@resend.dev per testejar)
RESEND_FROM_EMAIL="noreply@plainer.app"

# --- OpenAI --------------------------------------------------
OPENAI_API_KEY=""
