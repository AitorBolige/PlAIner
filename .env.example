# ============================================================
# PLAINER — Environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit real secrets to this file.
# ============================================================

# --- Database (Supabase) ------------------------------------
# Transaction pooler (port 6543) for runtime queries. Append ?pgbouncer=true.
DATABASE_URL=""
# Direct Postgres connection used by Prisma migrations.
DIRECT_URL=""

# --- Supabase JS client (Dashboard → Settings → API) --------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# --- NextAuth ------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# --- OAuth providers ----------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# --- Resend (transactional email) ---------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# --- AI providers -------------------------------------------
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# --- Mapbox (public token, restrict by domain in Mapbox Studio) ---
MAPBOX_TOKEN=""

# --- RapidAPI (travel) --------------------------------------
RAPIDAPI_KEY=""
RAPIDAPI_HOST=""
RAPIDAPI_FLIGHTS_HOST=""
RAPIDAPI_FLIGHTS_KEY=""
RAPIDAPI_FLIGHTS_PATH=""
RAPIDAPI_FLIGHTS_AUTOCOMPLETE_PATH=""

# --- Travel offers cache ------------------------------------
TRAVEL_OFFERS_INGEST_SECRET=""
TRAVEL_OFFERS_TTL_HOURS="12"
TRAVEL_HOTEL_SCRAPE_URL=""
TRAVEL_TRANSPORT_SCRAPE_URL=""
