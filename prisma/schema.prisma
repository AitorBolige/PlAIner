generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TravelSearchStatus {
  PENDING
  READY
  STALE
  ERROR
}

enum TravelOfferType {
  HOTEL
  TRANSPORT
}

enum TravelRefreshRunStatus {
  PENDING
  SUCCESS
  ERROR
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?

  ageGroup      String?   // "youth" | "adult" | "senior"
  travelStyles  String[]
  budgetMin     Int?
  budgetMax     Int?
  preferredDuration String?

  createdAt     DateTime  @default(now())

  trips          Trip[]
  accounts       Account[]
  sessions       Session[]
  passwordResets PasswordResetToken[]
}

model Trip {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination    String
  startDate      DateTime
  endDate        DateTime
  totalCost      Float
  flightCost     Float
  hotelCost      Float
  activitiesCost Float
  dailyCost      Float
  status         String    @default("draft") // draft | confirmed | completed
  isSurprise     Boolean   @default(false)
  isFavorite     Boolean   @default(false)
  days           Day[]
  createdAt      DateTime  @default(now())
}

model TravelSearch {
  id           String               @id @default(cuid())
  cacheKey     String               @unique
  destination  String
  city         String?
  countryCode  String?
  startDate    DateTime?
  endDate      DateTime?
  people       Int                  @default(2)
  budgetMax    Int?
  origin       String?
  maxPrice     Int?
  currency     String               @default("EUR")
  status       TravelSearchStatus   @default(PENDING)
  refreshedAt  DateTime?
  expiresAt    DateTime?
  offers       TravelOffer[]
  refreshRuns  TravelRefreshRun[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([destination, startDate, endDate])
  @@index([expiresAt])
}

model TravelOffer {
  id              String            @id @default(cuid())
  searchId        String
  search          TravelSearch      @relation(fields: [searchId], references: [id], onDelete: Cascade)
  type            TravelOfferType
  provider        String
  title           String
  description     String?
  price           Float
  currency        String            @default("EUR")
  bookingUrl      String
  sourceUrl       String?
  imageUrl        String?
  rating          Float?
  reviewCount     Int?
  availabilityText String?
  metadata        Json?
  rank            Int               @default(0)
  fetchedAt       DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([searchId, type, rank])
  @@index([provider])
}

model TravelRefreshRun {
  id              String                 @id @default(cuid())
  searchId        String
  search          TravelSearch           @relation(fields: [searchId], references: [id], onDelete: Cascade)
  status          TravelRefreshRunStatus @default(PENDING)
  providerSummary String?
  requestPayload  Json?
  errorMessage    String?
  resultCount     Int                    @default(0)
  startedAt       DateTime
  finishedAt      DateTime?
  createdAt       DateTime               @default(now())

  @@index([searchId, startedAt])
}

model Day {
  id         String     @id @default(cuid())
  tripId     String
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  dayNumber  Int
  title      String
  activities Activity[]

  @@unique([tripId, dayNumber])
}

model Activity {
  id          String  @id @default(cuid())
  dayId       String
  day         Day     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  name        String
  description String?
  startTime   String?
  duration    Int?
  cost        Float
  category    String?
  imageUrl    String?
  order       Int

  @@index([dayId, order])
}

// NextAuth (Prisma Adapter) models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  userId  String
  token   String   @unique
  expires DateTime
  used    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

